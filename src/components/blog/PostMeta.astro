---
import { formatDate, getLocaleFromPath, labelsFor, localizedPath } from '@utils/i18n';

interface Props {
  date: Date | string;
  tags?: string[];
  categories?: string[];
  readingTime?: number;
}

const { date, tags = [], categories = [], readingTime } = Astro.props;
const locale = getLocaleFromPath(Astro.url.pathname);
const t = labelsFor(locale);

const d = date instanceof Date ? date : new Date(date);
const formattedDate = formatDate(d, locale);
const isoDate = d.toISOString();
---

<div
  class="post-meta mt-1 flex flex-wrap items-center gap-2 text-xs"
  style="color: var(--global-text-color-light);"
>
  <time datetime={isoDate}>{formattedDate}</time>

  {
    readingTime && (
      <>
        <span aria-hidden="true">·</span>
        <span>
          {readingTime} {t.blog.minRead}
        </span>
      </>
    )
  }

  {
    categories.length > 0 && (
      <>
        <span aria-hidden="true">·</span>
        <div class="flex flex-wrap gap-1">
          {categories.map((cat) => (
            <a
              href={localizedPath(`/blog/category/${cat}/`, locale)}
              class="badge-abbr text-xs"
              style="background-color: var(--global-text-color-light); color: var(--global-hover-text-color);"
            >
              {cat}
            </a>
          ))}
        </div>
      </>
    )
  }

  {
    tags.length > 0 && (
      <>
        <span aria-hidden="true">·</span>
        <div class="flex flex-wrap gap-1">
          {tags.map((tag) => (
            <a
              href={localizedPath(`/blog/tag/${tag}/`, locale)}
              class="badge-abbr text-xs"
              style="background-color: var(--global-theme-color); color: var(--global-hover-text-color);"
            >
              {tag}
            </a>
          ))}
        </div>
      </>
    )
  }
</div>
