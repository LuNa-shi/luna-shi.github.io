---
import { site } from '@config/site';
import { getLocaleFromPath, labelsFor, localizedPath } from '@utils/i18n';
import { Icon } from 'astro-icon/components';

const displayTags = site.blog.displayTags;
const displayCategories = site.blog.displayCategories;
const locale = getLocaleFromPath(Astro.url.pathname);
const t = labelsFor(locale);
---

<section class="blog-filter-footer" aria-label={t.blog.filtersLabel}>
  <p class="blog-filter-note">{t.blog.description}</p>
  <div class="tag-category-list tag-category-list--footer">
    <ul class="m-0 p-0">
      {
        displayTags.map((tag, i) => (
          <>
            <li>
              <Icon name="fa-solid:hashtag" />{' '}
              <a href={localizedPath(`/blog/tag/${tag}/`, locale)}>{tag}</a>
            </li>
            {i < displayTags.length - 1 && <p>&bull;</p>}
          </>
        ))
      }
      {displayTags.length > 0 && displayCategories.length > 0 && <p>&bull;</p>}
      {
        displayCategories.map((cat, i) => (
          <>
            <li>
              <Icon name="fa-solid:folder" />{' '}
              <a href={localizedPath(`/blog/category/${cat}/`, locale)}>{cat}</a>
            </li>
            {i < displayCategories.length - 1 && <p>&bull;</p>}
          </>
        ))
      }
      {(displayTags.length > 0 || displayCategories.length > 0) && <p>&bull;</p>}
      <li>
        <Icon name="fa-solid:tags" />
        <a href={localizedPath('/blog/tags/', locale)}>{t.blog.allTags}</a>
      </li>
    </ul>
  </div>
</section>
