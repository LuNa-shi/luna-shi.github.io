---
import { withBase } from '@utils/base';
import {
  contentHref,
  contentSlug,
  formatDate,
  getLocaleFromPath,
  labelsFor,
  localizedPath,
} from '@utils/i18n';
import { readingTime } from '@utils/reading-time';
import type { CollectionEntry } from 'astro:content';
import { Icon } from 'astro-icon/components';

/** A local post from the 'posts' collection. */
type LocalPost = CollectionEntry<'posts'>;

/** A synthetic external post object (constructed in blog listing pages). */
interface ExternalPost {
  external: true;
  id: string;
  url: string;
  data: {
    title: string;
    date: Date;
    overview?: string;
    description?: string;
    tags: string[];
    categories: string[];
    image?: string;
  };
  body?: undefined;
}

type PostEntry = LocalPost | ExternalPost;

interface Props {
  post: PostEntry;
}

const { post } = Astro.props;
const locale = getLocaleFromPath(Astro.url.pathname);
const t = labelsFor(locale);

const isExternal = 'external' in post && post.external === true;

const title = post.data.title;
const date = post.data.date;
const description = post.data.overview ?? post.data.description;
const tags = post.data.tags ?? [];
const categories = post.data.categories ?? [];
// Use `image` field as thumbnail (matches schema field name)
const thumbnail = (post.data as { image?: string }).image;
const thumbnailSrc = thumbnail ? withBase(thumbnail) : undefined;

const href = isExternal
  ? (post as ExternalPost).url
  : contentHref('blog', contentSlug(post), locale);

const minutes =
  !isExternal && (post as LocalPost).body ? readingTime((post as LocalPost).body!) : undefined;

const d = date instanceof Date ? date : new Date(date);
const formattedDate = formatDate(d, locale);
const year = d.getFullYear();
---

{
  thumbnail ? (
    <div class="row">
      <div class="col-sm-9">
        <h3>
          <a
            class="post-title"
            href={href}
            {...(isExternal ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
          >
            {title}
            {isExternal && (
              <span style="font-size: 0.7em; opacity: 0.6; margin-left: 0.25em;">&#x2197;</span>
            )}
          </a>
        </h3>
        {description && <p>{description}</p>}
        <p class="post-meta">
          {minutes && (
            <>
              {minutes} {t.blog.minRead} &nbsp;&middot;&nbsp;{' '}
            </>
          )}
          <time datetime={d.toISOString()}>{formattedDate}</time>
        </p>
        <p class="post-tags">
          <a href={localizedPath('/blog/', locale)}>
            <Icon name="fa-solid:calendar" />
            &nbsp;{year}
          </a>
          {tags.map((tag) => (
            <>
              &nbsp;&middot;&nbsp;
              <a href={localizedPath(`/blog/tag/${tag}/`, locale)}>
                <Icon name="fa-solid:hashtag" />
                &nbsp;{tag}
              </a>
            </>
          ))}
          {categories.map((cat) => (
            <>
              &nbsp;&middot;&nbsp;
              <a href={localizedPath(`/blog/category/${cat}/`, locale)}>
                <Icon name="fa-solid:folder" />
                &nbsp;{cat}
              </a>
            </>
          ))}
        </p>
      </div>
      <div class="col-sm-3">
        <img
          class="img-fluid z-depth-1 rounded"
          src={thumbnailSrc}
          alt=""
          loading="lazy"
          width="150"
          height="120"
        />
      </div>
    </div>
  ) : (
    <>
      <h3>
        <a
          class="post-title"
          href={href}
          {...(isExternal ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
        >
          {title}
          {isExternal && (
            <span style="font-size: 0.7em; opacity: 0.6; margin-left: 0.25em;">&#x2197;</span>
          )}
        </a>
      </h3>
      {description && <p>{description}</p>}
      <p class="post-meta">
        {minutes && (
          <>
            {minutes} {t.blog.minRead} &nbsp;&middot;&nbsp;{' '}
          </>
        )}
        <time datetime={d.toISOString()}>{formattedDate}</time>
      </p>
      <p class="post-tags">
        <a href={localizedPath('/blog/', locale)}>
          <Icon name="fa-solid:calendar" />
          &nbsp;{year}
        </a>
        {tags.map((tag) => (
          <>
            &nbsp;&middot;&nbsp;
            <a href={localizedPath(`/blog/tag/${tag}/`, locale)}>
              <Icon name="fa-solid:hashtag" />
              &nbsp;{tag}
            </a>
          </>
        ))}
        {categories.map((cat) => (
          <>
            &nbsp;&middot;&nbsp;
            <a href={localizedPath(`/blog/category/${cat}/`, locale)}>
              <Icon name="fa-solid:folder" />
              &nbsp;{cat}
            </a>
          </>
        ))}
      </p>
    </>
  )
}
