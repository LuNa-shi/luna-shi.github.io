---
import type { MarkdownHeading } from 'astro';

interface Props {
  headings: MarkdownHeading[];
}

const { headings } = Astro.props;

// Only render h2 and h3
const tocHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);
if (tocHeadings.length === 0) return;
---

<nav aria-label="Table of contents" class="toc toc-floating" tabindex="0">
  <div class="toc-rail" aria-hidden="true">
    <span></span>
    <span></span>
    <span></span>
    <span></span>
  </div>
  <div class="toc-panel">
    <p class="toc-title">Contents</p>
    <ul class="toc-list">
      {
        tocHeadings.map((h) => (
          <li class={h.depth === 3 ? 'is-child' : ''}>
            <a href={`#${h.slug}`} class="toc-link">
              {h.text}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</nav>

<script>
  // Highlight the active heading as user scrolls
  const links = document.querySelectorAll<HTMLAnchorElement>('.toc-link');
  const headingIds = Array.from(links).map((l) => l.getAttribute('href')?.slice(1) ?? '');

  function setActive(id: string) {
    links.forEach((l) => {
      const isActive = l.getAttribute('href') === `#${id}`;
      l.style.color = isActive ? 'var(--global-theme-color)' : 'var(--global-text-color-light)';
      l.style.fontWeight = isActive ? '600' : '400';
      l.setAttribute('aria-current', isActive ? 'true' : 'false');
    });
  }

  const navbarHeight =
    parseInt(getComputedStyle(document.documentElement).getPropertyValue('--navbar-height')) || 57;

  const observer = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          setActive(entry.target.id);
          break;
        }
      }
    },
    { rootMargin: `-${navbarHeight}px 0px -80% 0px`, threshold: 0 },
  );

  headingIds.forEach((id) => {
    const el = document.getElementById(id);
    if (el) observer.observe(el);
  });
</script>

<style>
  .toc-floating {
    display: none;
  }

  @media (min-width: 1180px) {
    .toc-floating {
      display: block;
      position: fixed;
      top: calc(var(--navbar-height) + 4.5rem);
      right: 1.1rem;
      z-index: 30;
      width: 2rem;
      height: 4.5rem;
      max-height: calc(100vh - var(--navbar-height) - 2.5rem);
      overflow: hidden;
      border: 1px solid rgba(96, 82, 105, 0.12);
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.22);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      box-shadow: none;
      color: var(--global-text-color-light);
      font-size: 0.8rem;
      outline: none;
      transition:
        width 0.18s ease,
        height 0.18s ease,
        border-radius 0.18s ease,
        background-color 0.18s ease,
        border-color 0.18s ease,
        box-shadow 0.18s ease;
    }

    .toc-floating:hover,
    .toc-floating:focus-within {
      width: min(16rem, calc(100vw - 2rem));
      height: min(42rem, calc(100vh - var(--navbar-height) - 2.5rem));
      border-radius: 8px;
      border-color: rgba(96, 82, 105, 0.14);
      background: rgba(255, 255, 255, 0.84);
      box-shadow: 0 18px 44px rgba(38, 22, 51, 0.1);
    }

    .toc-rail {
      position: absolute;
      inset: 0;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 0.34rem;
      pointer-events: none;
      transition: opacity 0.16s ease;
    }

    .toc-rail span {
      display: block;
      width: 0.9rem;
      height: 2px;
      border-radius: 999px;
      background: rgba(126, 96, 132, 0.34);
    }

    .toc-rail span:nth-child(2) {
      width: 1.2rem;
    }

    .toc-rail span:nth-child(3) {
      width: 0.72rem;
    }

    .toc-rail span:nth-child(4) {
      width: 1rem;
    }

    .toc-floating:hover .toc-rail,
    .toc-floating:focus-within .toc-rail {
      opacity: 0;
    }

    .toc-panel {
      max-height: min(42rem, calc(100vh - var(--navbar-height) - 2.5rem));
      overflow-y: auto;
      padding: 0.95rem 1rem;
      opacity: 0;
      pointer-events: none;
      transform: translateX(0.5rem);
      transition:
        opacity 0.16s ease,
        transform 0.16s ease;
      scrollbar-width: thin;
      scrollbar-color: rgba(181, 9, 172, 0.22) transparent;
    }

    .toc-floating:hover .toc-panel,
    .toc-floating:focus-within .toc-panel {
      opacity: 1;
      pointer-events: auto;
      transform: translateX(0);
    }

    .toc-title {
      margin: 0 0 0.6rem;
      color: var(--global-text-color-light);
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .toc-list {
      list-style: none;
      margin: 0;
      padding: 0;
    }

    .toc-list li {
      margin: 0;
      padding: 0;
    }

    .toc-list li.is-child {
      padding-left: 0.75rem;
    }

    .toc-link {
      display: block;
      padding: 0.22rem 0;
      color: var(--global-text-color-light);
      line-height: 1.35;
      text-decoration: none;
      transition: color 0.12s ease;
    }

    .toc-link[aria-current='true'] {
      color: var(--global-theme-color);
      font-weight: 600;
    }

    html[data-theme='dark'] .toc-floating {
      border-color: rgba(160, 170, 180, 0.18);
      background: rgba(28, 28, 29, 0.3);
      box-shadow: none;
    }

    html[data-theme='dark'] .toc-rail span {
      background: rgba(142, 180, 190, 0.34);
    }

    html[data-theme='dark'] .toc-floating:hover,
    html[data-theme='dark'] .toc-floating:focus-within {
      border-color: rgba(160, 170, 180, 0.26);
      background: rgba(28, 28, 29, 0.86);
      box-shadow: 0 16px 36px rgba(0, 0, 0, 0.22);
    }
  }

  .toc-link:hover {
    color: var(--global-theme-color) !important;
  }
</style>
