---
import '@styles/global.css';

import Footer from '@components/Footer.astro';
import Navbar from '@components/Navbar.astro';
import SearchTrigger from '@components/search/SearchTrigger.astro';
import VariantSwitch from '@components/VariantSwitch.astro';
import { site } from '@config/site';
import { getLocaleFromPath, labelsFor, localizedCurrentPath } from '@utils/i18n';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
  /** OG preview image (absolute URL or path) */
  image?: string;
  noindex?: boolean;
  /** Override the robots meta tag content string (e.g. 'noindex, nofollow'). */
  robots?: string;
  /** Whether this is the homepage — injects Person JSON-LD when true */
  isHome?: boolean;
}

const locale = getLocaleFromPath(Astro.url.pathname);
const t = labelsFor(locale);

const {
  title = site.author.name,
  description = t.siteDescription,
  image = site.og.image || undefined,
  noindex = false,
  robots,
  isHome = false,
} = Astro.props;

const pageTitle = title === site.author.name ? title : `${title} | ${site.author.name}`;
const canonicalURL = new URL(Astro.url.pathname, site.url);
const alternateEn = new URL(localizedCurrentPath(Astro.url.pathname, 'en'), site.url);
const alternateZh = new URL(localizedCurrentPath(Astro.url.pathname, 'zh'), site.url);
// Prepend base path to root-relative images before resolving to absolute URL
const resolvedImage = image?.startsWith('/')
  ? `${import.meta.env.BASE_URL}${image.slice(1)}`
  : image;
const ogImage = resolvedImage ? new URL(resolvedImage, site.url).toString() : undefined;

// Light-only theme color override.
const lightColor = site.theme.color.light === 'auto' ? null : site.theme.color.light;
const colorOverrideStyle = [
  lightColor
    ? `:root,[data-theme='light']{--global-theme-color:${lightColor};--global-hover-color:${lightColor};}`
    : '',
]
  .filter(Boolean)
  .join('');

// Person JSON-LD for homepage — helps search engines associate content with the author
const personJsonLd = isHome ? JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: site.author.name,
  url: site.url,
  email: site.author.email || undefined,
  sameAs: [
    site.socials.orcid_id ? `https://orcid.org/${site.socials.orcid_id}` : null,
    site.socials.scholar_userid ? `https://scholar.google.com/citations?user=${site.socials.scholar_userid}` : null,
    site.socials.github_username ? `https://github.com/${site.socials.github_username}` : null,
  ].filter(Boolean),
}) : null;
---

<!doctype html>
<html lang={locale === 'zh' ? 'zh-CN' : site.lang} data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    {(robots || noindex) && <meta name="robots" content={robots ?? 'noindex, nofollow'} />}

    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" hreflang="en" href={alternateEn} />
    <link rel="alternate" hreflang="zh-CN" href={alternateZh} />
    <link rel="alternate" hreflang="x-default" href={alternateEn} />
    <title>{pageTitle}</title>

    <!-- Favicon -->
    <link rel="icon" href={`${site.base}/favicon.svg`} type="image/svg+xml" />
    <link rel="alternate icon" href={`${site.base}/favicon.ico`} />

    <!-- Fonts are self-hosted via Fontsource (imported in global.css) — no FOUT -->

    <!-- KaTeX CSS is bundled via global.css (@import 'katex/dist/katex.min.css') -->

    <!-- Theme color override (from site.theme.color — 'auto' means use _colors.css defaults) -->
    {colorOverrideStyle && <Fragment set:html={`<style>${colorOverrideStyle}</style>`} />}

    <!-- Open Graph + Twitter Card -->
    {
      site.og.enabled && (
        <>
          <meta property="og:title" content={pageTitle} />
          <meta property="og:description" content={description} />
          <meta property="og:url" content={canonicalURL} />
          <meta property="og:type" content="website" />
          {ogImage && <meta property="og:image" content={ogImage} />}
          <meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
          <meta name="twitter:title" content={pageTitle} />
          <meta name="twitter:description" content={description} />
          {ogImage && <meta name="twitter:image" content={ogImage} />}
          {site.socials.x_username && <meta name="twitter:site" content={`@${site.socials.x_username}`} />}
        </>
      )
    }

    <!-- Analytics verification tags -->
    {
      site.analytics.googleVerification && (
        <meta name="google-site-verification" content={site.analytics.googleVerification} />
      )
    }
    {
      site.analytics.bingVerification && (
        <meta name="msvalidate.01" content={site.analytics.bingVerification} />
      )
    }

    <!-- GA4 via Partytown (production only) -->
    {
      import.meta.env.PROD && site.analytics.ga4 && (
        <>
          <script
            type="text/partytown"
            src={`https://www.googletagmanager.com/gtag/js?id=${site.analytics.ga4}`}
          />
          <script type="text/partytown" define:vars={{ ga4: site.analytics.ga4 }}>
            window.dataLayer = window.dataLayer || [];
            function gtag() {
              dataLayer.push(arguments);
            }
            gtag('js', new Date());
            gtag('config', ga4);
          </script>
        </>
      )
    }

    <!-- Cronitor RUM -->
    {
      import.meta.env.PROD && site.analytics.cronitor && (
        <script
          define:vars={{ siteId: site.analytics.cronitor }}
          is:inline
        >{`!function(p,a,t,h,w,n,k){p.cronitor||(p.cronitor=function(){(p.cronitor.q=p.cronitor.q||[]).push(arguments)}),h=a.getElementsByTagName("script")[0],(k=a.createElement("script")).setAttribute("async",!0),k.setAttribute("src","https://rum.cronitor.io/script.js"),k.setAttribute("data-site-id",siteId),h.parentNode.insertBefore(k,h)}(window,document);`}</script>
      )
    }

    <!-- Pirsch analytics -->
    {
      import.meta.env.PROD && site.analytics.pirsch && (
        <script
          defer
          src="https://api.pirsch.io/pa.js"
          id="pianjs"
          data-code={site.analytics.pirsch}
        ></script>
      )
    }

    <!-- OpenPanel analytics -->
    {
      import.meta.env.PROD && site.analytics.openpanel && (
        <script
          define:vars={{ clientId: site.analytics.openpanel }}
          is:inline
        >{`(function(w,d,s){var c=d.createElement(s);c.src="https://openpanel.dev/op1.js";c.defer=true;c.setAttribute("data-client-id",clientId);d.head.appendChild(c);})(window,document,"script");`}</script>
      )
    }

    <!-- Person JSON-LD (homepage only) -->
    {personJsonLd && <script type="application/ld+json" set:html={personJsonLd} />}

    <!-- View Transitions (smooth page-to-page navigation) -->
    {site.features.viewTransitions && <ClientRouter />}

    <!-- Named slot for page-specific head content (e.g. JSON-LD from Post.astro) -->
    <slot name="head" />

    <script
      is:inline
      define:vars={{ defaultVariant: site.theme.variant, allowOverride: site.theme.previewVariants }}
    >
      function applyTheme() {
        var el = document.documentElement;
        el.setAttribute('data-theme', 'light');
        el.setAttribute('data-theme-setting', 'light');
        // Editorial variant (clay · slate · ink). When previewing, ?variant=
        // overrides + persists, else localStorage, else the committed default.
        // When locked (previewVariants=false) always use the committed default,
        // ignoring any stale localStorage. Set before first paint (no flash).
        var v = defaultVariant;
        if (allowOverride) {
          try {
            var q = new URL(window.location.href).searchParams.get('variant');
            if (q) localStorage.setItem('site-variant', q);
            v = localStorage.getItem('site-variant') || defaultVariant;
          } catch (e) {
            /* private mode */
          }
        }
        el.setAttribute('data-variant', v);
        // Enables scroll-reveal hiding only when JS is live (no-JS stays visible).
        el.classList.add('reveal-ready');
      }
      applyTheme();
      document.addEventListener('astro:after-swap', applyTheme);
    </script>

    <!-- No-JS / observer-failure failsafe: never leave reveal content hidden. -->
    <noscript>
      <style>
        [data-reveal] {
          opacity: 1 !important;
          transform: none !important;
        }
      </style>
    </noscript>
  </head>

  <body
    class="min-h-screen flex flex-col"
    style="padding-top: var(--navbar-height);"
    data-footer-position={site.footer.position}
    data-tooltips={site.features.tooltips ? 'true' : undefined}
  >
    <!-- Skip to main content (accessibility) -->
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 z-50 px-4 py-2 rounded"
      style="background-color: var(--global-theme-color); color: var(--global-hover-text-color);"
    >
      {t.base.skipToContent}
    </a>

    <Navbar />

    <!-- ⌘K Search (ninja-keys + Pagefind) — persisted across View Transitions -->
    {site.features.search && <SearchTrigger transition:persist />}

    <main id="main-content" class="flex-1" data-pagefind-body>
      <slot />
    </main>

    <!-- Newsletter (shown in footer area if enabled) -->
    {site.features.newsletter && <slot name="newsletter" />}

    {site.footer.position !== 'hidden' && <Footer />}

    <!-- Cookie consent (vanilla-cookieconsent via CDN) -->
    {
      site.features.cookieConsent && (
        <>
          <link
            rel="stylesheet"
            href="https://cdn.jsdelivr.net/gh/orestbida/cookieconsent@3.0.1/dist/cookieconsent.css"
          />
          <script
            src="https://cdn.jsdelivr.net/gh/orestbida/cookieconsent@3.0.1/dist/cookieconsent.umd.js"
            defer
          ></script>
          <script is:inline define:vars={{ cookieLabels: t.cookies }}>{`
            window.addEventListener('load', function() {
              if (typeof CookieConsent === 'undefined') return;
              CookieConsent.run({
                categories: {
                  necessary: { enabled: true, readOnly: true },
                  analytics: {}
                },
                language: {
                  default: 'en',
                  translations: {
                    en: {
                      consentModal: {
                        title: cookieLabels.title,
                        description: cookieLabels.description,
                        acceptAllBtn: cookieLabels.acceptAll,
                        acceptNecessaryBtn: cookieLabels.rejectAll,
                        showPreferencesBtn: cookieLabels.manage
                      },
                      preferencesModal: {
                        title: cookieLabels.preferencesTitle,
                        acceptAllBtn: cookieLabels.acceptAll,
                        acceptNecessaryBtn: cookieLabels.rejectAll,
                        savePreferencesBtn: cookieLabels.save,
                        sections: [
                          { title: cookieLabels.necessaryTitle, description: cookieLabels.necessaryDescription, linkedCategory: 'necessary' },
                          { title: cookieLabels.analyticsTitle, description: cookieLabels.analyticsDescription, linkedCategory: 'analytics' }
                        ]
                      }
                    }
                  }
                }
              });
            });
          `}</script>
        </>
      )
    }

    <!-- Variant preview switcher (clay · slate · ink) — only when previewing -->
    {site.theme.previewVariants && <VariantSwitch />}

    <!-- Back to top button -->
    <button id="back-to-top" aria-label={t.base.backToTop} title={t.base.backToTop}>
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="m18 15-6-6-6 6"></path>
      </svg>
    </button>

    <script>
      let btn = document.getElementById('back-to-top');

      function updateVisibility() {
        btn?.classList.toggle('visible', window.scrollY > 300);
      }

      function attachClick() {
        btn?.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
      }

      window.addEventListener('scroll', updateVisibility, { passive: true });
      attachClick();

      // After each View Transition the DOM is swapped — re-query the new element,
      // re-attach the click handler, and re-evaluate visibility immediately
      // (the scroll event doesn't fire when the browser resets scroll position).
      document.addEventListener('astro:after-swap', () => {
        btn = document.getElementById('back-to-top');
        attachClick();
        updateVisibility();
      });
    </script>

    <!-- Scroll-reveal: fade/rise [data-reveal] elements into view once. -->
    <script>
      function initReveal() {
        const els = document.querySelectorAll('[data-reveal]:not([data-reveal-done])');
        if (!els.length) return;
        if (
          !('IntersectionObserver' in window) ||
          window.matchMedia('(prefers-reduced-motion: reduce)').matches
        ) {
          els.forEach((e) => {
            e.setAttribute('data-reveal-done', '');
            e.classList.add('is-visible');
          });
          return;
        }
        const io = new IntersectionObserver(
          (entries, obs) => {
            entries.forEach((en) => {
              if (en.isIntersecting) {
                en.target.classList.add('is-visible');
                obs.unobserve(en.target);
              }
            });
          },
          { rootMargin: '0px 0px -8% 0px', threshold: 0.06 },
        );
        els.forEach((e) => {
          e.setAttribute('data-reveal-done', '');
          io.observe(e);
        });
      }
      initReveal();
      document.addEventListener('astro:page-load', initReveal);
    </script>
  </body>
</html>
