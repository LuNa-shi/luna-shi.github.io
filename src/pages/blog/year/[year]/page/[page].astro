---
import PostCard from '@components/blog/PostCard.astro';
import Pagination from '@components/Pagination.astro';
import { site } from '@config/site';
import PageLayout from '@layouts/Page.astro';
import {
  formatMessage,
  getLocaleFromPath,
  isEntryInLocale,
  labelsFor,
  localizedPath,
} from '@utils/i18n';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allPosts = await getCollection(
    'posts',
    (p) => !p.data.hidden && !p.data.draft && isEntryInLocale(p, 'en'),
  );
  const perPage = site.blog.postsPerPage;
  const years = [...new Set(allPosts.map((p) => p.data.date.getFullYear()))];

  return years.flatMap((year) => {
    const yearPosts = allPosts
      .filter((p) => p.data.date.getFullYear() === year)
      .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
    const totalPages = Math.ceil(yearPosts.length / perPage);
    return Array.from({ length: Math.max(0, totalPages - 1) }, (_, i) => {
      const page = i + 2;
      return {
        params: { year: String(year), page: String(page) },
        props: {
          year,
          posts: yearPosts.slice((page - 1) * perPage, page * perPage),
          currentPage: page,
          totalPages,
        },
      };
    });
  });
}

const { year, posts, currentPage, totalPages } = Astro.props;
const locale = getLocaleFromPath(Astro.url.pathname);
const t = labelsFor(locale);
---

<PageLayout
  title={formatMessage(t.blog.yearPageTitle, { year, page: currentPage })}
  description={formatMessage(t.blog.yearPageDescription, { year, page: currentPage })}
>
  <div class="post">
    <header class="post-header">
      <h1 class="post-title">{year}</h1>
      <p>
        <a href={localizedPath('/blog/', locale)} style="color: var(--global-theme-color);"
          >← {t.blog.backToBlog}</a
        >
      </p>
    </header>
    <ul class="post-list">
      {
        posts.map((post) => (
          <li>
            <PostCard post={post} />
          </li>
        ))
      }
    </ul>
    <Pagination
      currentPage={currentPage}
      totalPages={totalPages}
      prevUrl={currentPage === 2
        ? localizedPath(`/blog/year/${year}/`, locale)
        : localizedPath(`/blog/year/${year}/page/${currentPage - 1}/`, locale)}
      nextUrl={currentPage < totalPages
        ? localizedPath(`/blog/year/${year}/page/${currentPage + 1}/`, locale)
        : undefined}
      basePath={localizedPath(`/blog/year/${year}/`, locale)}
    />
  </div>
</PageLayout>
