---
import Page from '@layouts/Page.astro';
import { formatDate, getLocaleFromPath, isEntryInLocale, labelsFor } from '@utils/i18n';
import { getCollection, render } from 'astro:content';

const locale = getLocaleFromPath(Astro.url.pathname);
const t = labelsFor(locale);
const announcements = (await getCollection('announcements'))
  .filter((e) => !e.data.hidden && isEntryInLocale(e, locale))
  .sort((a, b) => {
    if (a.data.pinned !== b.data.pinned) return a.data.pinned ? -1 : 1;
    return b.data.date.getTime() - a.data.date.getTime();
  });

const rendered = await Promise.all(
  announcements.map(async (item) => ({ item, rendered: await render(item) })),
);
---

<Page title={t.news.title} description={t.news.description}>
  <div class="post">
    <header class="post-header">
      <h1 class="post-title">{t.news.heading}</h1>
    </header>
    <article>
      {
        rendered.length === 0 ? (
          <p style="color: var(--global-text-color-light);">{t.news.empty}</p>
        ) : (
          <table style="width: 100%; border-collapse: collapse;">
            <tbody>
              {rendered.map(({ item, rendered: { Content } }) => (
                <tr style="border-bottom: 1px solid var(--global-divider-color);">
                  <td style="padding: 0.5rem 1rem 0.5rem 0; white-space: nowrap; vertical-align: top; color: var(--global-text-color-light); font-size: 0.8rem;">
                    {formatDate(item.data.date, locale, {
                      year: 'numeric',
                      month: 'short',
                      day: 'numeric',
                    })}
                  </td>
                  <td style="padding: 0.5rem 0; font-size: 0.9rem; color: var(--global-text-color);">
                    <Content />
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        )
      }
    </article>
  </div>
</Page>

<style>
  .post-header {
    margin-bottom: 1.5rem;
  }

  .post-title {
    font-size: 2rem;
    font-weight: 700;
    color: var(--global-text-color);
    font-family: var(--font-sans);
    margin-bottom: 0;
  }
</style>
