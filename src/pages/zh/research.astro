---
import Page from '@layouts/Page.astro';
import { getLocaleFromPath, labelsFor } from '@utils/i18n';

const locale = getLocaleFromPath(Astro.url.pathname);
const t = labelsFor(locale);
---

<Page title={t.research.title} description={t.research.description}>
  <div class="post">
    <header class="post-header">
      <h1 class="post-title">{t.research.heading}</h1>
      <p class="post-description">
        {t.research.intro}
      </p>
    </header>

    <article class="research-page">
      {
        t.research.sections.map((section) => (
          <section>
            <h2>{section.title}</h2>
            <p>
              {section.body}
              {'linkText' in section && section.linkText && (
                <>
                  {' '}
                  <a href="https://dequan.wang/" target="_blank" rel="noopener noreferrer">
                    {section.linkText}
                  </a>
                  .
                </>
              )}
            </p>
          </section>
        ))
      }
    </article>
  </div>
</Page>

<style>
  .post {
    padding-top: 0;
  }

  .post-description {
    color: var(--global-text-color-light);
    font-size: 1rem;
    max-width: 44rem;
  }

  .research-page {
    display: grid;
    gap: 1.25rem;
  }

  .research-page section {
    border-left: 3px solid var(--global-theme-color);
    padding-left: 1rem;
  }

  .research-page h2 {
    color: var(--global-text-color);
    font-family: var(--font-sans);
    font-size: 1.2rem;
    font-weight: 650;
    margin: 0 0 0.4rem;
  }

  .research-page p {
    color: var(--global-text-color);
    line-height: 1.75;
    margin: 0;
  }
</style>
