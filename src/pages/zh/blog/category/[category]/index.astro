---
import PostCard from '@components/blog/PostCard.astro';
import Pagination from '@components/Pagination.astro';
import { site } from '@config/site';
import Page from '@layouts/Page.astro';
import {
  formatMessage,
  getLocaleFromPath,
  isEntryInLocale,
  labelsFor,
  localizedPath,
} from '@utils/i18n';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allPosts = await getCollection('posts');
  const perPage = site.blog.postsPerPage;
  const localePosts = allPosts.filter((p) => isEntryInLocale(p, 'zh'));
  const postCategories = localePosts.flatMap((p) => p.data.categories);
  const allCategories = [...new Set([...postCategories, ...site.blog.displayCategories])];

  return allCategories.map((category) => {
    const catPosts = localePosts
      .filter((p) => !p.data.hidden && !p.data.draft && p.data.categories.includes(category))
      .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
    const totalPages = Math.max(1, Math.ceil(catPosts.length / perPage));
    return {
      params: { category },
      props: {
        posts: catPosts.slice(0, perPage),
        currentPage: 1,
        totalPages,
      },
    };
  });
}

const { category } = Astro.params;
const { posts, currentPage, totalPages } = Astro.props;
const locale = getLocaleFromPath(Astro.url.pathname);
const t = labelsFor(locale);
---

<Page
  title={formatMessage(t.blog.categoryTitle, { category })}
  description={formatMessage(t.blog.categoryDescription, { category })}
>
  <div class="mb-6">
    <a
      href={localizedPath('/blog/', locale)}
      class="text-sm"
      style="color: var(--global-theme-color); text-decoration: none;"
    >
      &larr; {t.blog.allPosts}
    </a>
  </div>

  <h1
    class="mb-6 text-3xl font-bold"
    style="color: var(--global-text-color); font-family: var(--font-sans);"
  >
    {t.blog.category}
    <span
      class="badge-abbr ml-2"
      style="background-color: var(--global-text-color-light); color: var(--global-hover-text-color);"
    >
      {category}
    </span>
  </h1>

  {
    posts.length === 0 ? (
      <p style="color: var(--global-text-color-light);">{t.blog.noPostsForCategory}</p>
    ) : (
      <ul class="post-list">
        {posts.map((post) => (
          <li>
            <PostCard post={post} />
          </li>
        ))}
      </ul>
    )
  }

  <Pagination
    currentPage={currentPage}
    totalPages={totalPages}
    prevUrl={undefined}
    nextUrl={totalPages > 1
      ? localizedPath(`/blog/category/${category}/page/2/`, locale)
      : undefined}
    basePath={localizedPath(`/blog/category/${category}/`, locale)}
  />
</Page>
