---
import Page from '@layouts/Page.astro';
import { getLocaleFromPath, isEntryInLocale, labelsFor, localizedPath } from '@utils/i18n';
import { getCollection } from 'astro:content';

const locale = getLocaleFromPath(Astro.url.pathname);
const t = labelsFor(locale);
const posts = await getCollection(
  'posts',
  (p) => !p.data.hidden && !p.data.draft && isEntryInLocale(p, locale),
);

const tagCounts = new Map<string, number>();
for (const post of posts) {
  for (const tag of post.data.tags ?? []) {
    tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1);
  }
}

const maxCount = Math.max(...tagCounts.values(), 1);
const tags = [...tagCounts.entries()].sort((a, b) => b[1] - a[1]);
---

<Page title={t.blog.tagsPageTitle} description={t.blog.tagsDescription}>
  <div class="post">
    <header class="post-header">
      <h1 class="post-title">{t.blog.tagsTitle}</h1>
      <p>
        <a href={localizedPath('/blog/', locale)} style="color: var(--global-theme-color);"
          >← {t.blog.backToBlog}</a
        >
      </p>
    </header>
    {
      tags.length === 0 ? (
        <p style="color: var(--global-text-color-light);">{t.blog.noTags}</p>
      ) : (
        <div class="tag-cloud">
          {tags.map(([tag, count]) => {
            const size = 0.8 + (count / maxCount) * 1.2;
            return (
              <a
                href={localizedPath(`/blog/tag/${tag}/`, locale)}
                class="tag-item"
                style={`font-size: ${size}rem;`}
                title={`${count}`}
              >
                {tag}
                <sup class="tag-count">{count}</sup>
              </a>
            );
          })}
        </div>
      )
    }
  </div>
</Page>

<style>
  .tag-cloud {
    line-height: 2.8;
    text-align: center;
    padding: 1rem 0;
  }

  .tag-item {
    display: inline-block;
    margin: 0.2rem 0.4rem;
    color: var(--global-theme-color);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .tag-item:hover {
    color: var(--global-hover-color);
  }

  .tag-count {
    font-size: 0.6rem;
    color: var(--global-text-color-light);
    vertical-align: super;
  }
</style>
