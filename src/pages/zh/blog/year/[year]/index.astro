---
import PostCard from '@components/blog/PostCard.astro';
import Pagination from '@components/Pagination.astro';
import { site } from '@config/site';
import Page from '@layouts/Page.astro';
import {
  formatMessage,
  getLocaleFromPath,
  isEntryInLocale,
  labelsFor,
  localizedPath,
} from '@utils/i18n';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allPosts = await getCollection(
    'posts',
    (p) => !p.data.hidden && !p.data.draft && isEntryInLocale(p, 'zh'),
  );
  const perPage = site.blog.postsPerPage;
  const years = [...new Set(allPosts.map((p) => p.data.date.getFullYear()))];

  return years.map((year) => {
    const yearPosts = allPosts
      .filter((p) => p.data.date.getFullYear() === year)
      .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
    const totalPages = Math.max(1, Math.ceil(yearPosts.length / perPage));
    return {
      params: { year: String(year) },
      props: {
        year,
        posts: yearPosts.slice(0, perPage),
        currentPage: 1,
        totalPages,
      },
    };
  });
}

const { year, posts, currentPage, totalPages } = Astro.props;
const locale = getLocaleFromPath(Astro.url.pathname);
const t = labelsFor(locale);
---

<Page
  title={formatMessage(t.blog.yearTitle, { year })}
  description={formatMessage(t.blog.yearDescription, { year })}
>
  <div class="post">
    <header class="post-header">
      <h1 class="post-title">{year}</h1>
      <p>
        <a href={localizedPath('/blog/', locale)} style="color: var(--global-theme-color);"
          >← {t.blog.backToBlog}</a
        >
      </p>
    </header>
    <ul class="post-list">
      {
        posts.map((post) => (
          <li>
            <PostCard post={post} />
          </li>
        ))
      }
    </ul>
    <Pagination
      currentPage={currentPage}
      totalPages={totalPages}
      prevUrl={undefined}
      nextUrl={totalPages > 1 ? localizedPath(`/blog/year/${year}/page/2/`, locale) : undefined}
      basePath={localizedPath(`/blog/year/${year}/`, locale)}
    />
  </div>
</Page>
